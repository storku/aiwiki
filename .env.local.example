# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/aiwiki?sslmode=require

# Vercel Blob storage token (for image uploads)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Editor authentication secret (used for admin access and session signing)
EDITOR_SECRET=your-editor-secret-here

# On-demand revalidation secret (for /api/revalidate endpoint)
REVALIDATE_SECRET=your-revalidation-secret-here
